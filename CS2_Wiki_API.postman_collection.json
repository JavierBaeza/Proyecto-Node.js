								"{{base_url}}"
							],
							"path": [
								"categorias"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nombre\": \"Granadas\",\n  \"descripcion\": \"Equipamiento arrojadizo táctico y utilidades.\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"description": "Crea una nueva categoría."
					}
				},
				{
					"name": "14. POST crear subcategoría",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/subcategorias",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"subcategorias"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id_categoria\": 1,\n  \"nombre\": \"Rifles de Francotirador Especiales\",\n  \"descripcion\": \"Fusiles de alta precisión para combate a distancia.\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"description": "Crea una nueva subcategoría vinculada a una categoría."
					}
				}
			]
		},
		{
			"name": "PUT",
