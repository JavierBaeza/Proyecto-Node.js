{
	"info": {
		"name": "CS2 Wiki API",
		"description": "Colección completa para probar los 19 endpoints de la CS2 Wiki.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:3000/api",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "GET",
			"item": [
				{
					"name": "1. GET todas las armas",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/armas",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"armas"
							]
						},
						"description": "Devuelve todas las armas con su categoría y subcategoría. Esperado: 200 OK + array de armas."
					}
				},
				{
					"name": "2. GET arma por ID",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/armas/1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"armas",
								"1"
							]
						},
						"description": "Devuelve el detalle de un arma con sus skins. Esperado: 200 OK."
					}
				},
				{
					"name": "11. GET todas las categorías con cantidades de armas",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/categorias",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"categorias"
							]
						},
						"description": "Devuelve todas las categorías registradas junto a la cantidad de armas asociadas a cada una."
					}
				},
				{
					"name": "12. GET subcategorías con respectivas armas",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{base_url}}/subcategorias/armas",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"subcategorias",
								"armas"
							]
						},
						"description": "Devuelve la lista de subcategorías con sus armas asociadas."
					}
				}
			]
		},
		{
			"name": "POST",
			"item": [
				{
					"name": "3. POST crear arma",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/armas",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"armas"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id_categoria\": 1,\n  \"id_subcategoria\": 1,\n  \"nombre\": \"AWP\",\n  \"bando\": \"AM\",\n  \"precio\": 4750,\n  \"dano_base\": 115,\n  \"balas_cargador\": 10\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"description": "Crea una nueva arma (opcionalmente asociada a una id_subcategoria)."
					}
				},
				{
					"name": "4. POST crear skin para un arma",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/armas/1/skins",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"armas",
								"1",
								"skins"
							]
						},
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nombre_skin\": \"Dragon Lore\",\n  \"rareza\": \"Covert\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"description": "Crea una skin vinculada al arma con id=1."
					}
				},
				{
					"name": "13. POST crear categoría",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/categorias",
